---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_URL, ADSENSE_ID, SIDEBAR_ADS } from '../consts';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category, tags } = Astro.props;
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<html lang="ja">
	<head>
		<BaseHead title={`${title} | ${SITE_TITLE}`} description={description} />
		<!-- Structured Data: Article + BreadcrumbList -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Article",
			"headline": title,
			"description": description,
			"datePublished": pubDate.toISOString(),
			"dateModified": updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
			"author": {
				"@type": "Organization",
				"name": SITE_TITLE
			},
			"publisher": {
				"@type": "Organization",
				"name": SITE_TITLE
			},
			"mainEntityOfPage": {
				"@type": "WebPage",
				"@id": Astro.url.href
			},
			"articleSection": category || "General",
			"keywords": tags ? tags.join(", ") : ""
		})}></script>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": "ホーム",
					"item": new URL("/", Astro.site).href
				},
				{
					"@type": "ListItem",
					"position": 2,
					"name": "記事一覧",
					"item": new URL("/blog/", Astro.site).href
				},
				{
					"@type": "ListItem",
					"position": 3,
					"name": title
				}
			]
		})}></script>
		<style>
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				max-width: 100%;
				padding: 0;
			}
			.article-header {
				margin-bottom: 2em;
				padding-bottom: 1em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.article-meta {
				display: flex;
				align-items: center;
				gap: 1em;
				margin-bottom: 0.8em;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.article-header h1 {
				font-size: 1.8em;
				line-height: 1.4;
				margin: 0.3em 0;
			}
			.article-desc {
				color: rgb(var(--gray));
				font-size: 0.95em;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
				margin-top: 0.8em;
			}
			.last-updated {
				font-style: italic;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.prose :global(h2) {
				margin-top: 2.5em;
			}
			.prose :global(h3) {
				margin-top: 1.5em;
			}
			.prose :global(ul), .prose :global(ol) {
				padding-left: 1.5em;
				margin-bottom: 1.5em;
			}
			.prose :global(li) {
				margin-bottom: 0.4em;
			}
			.prose :global(.cta-box) {
				margin: 2.5em 0;
			}
			@media (max-width: 720px) {
				.article-header h1 { font-size: 1.4em; }
			}
		</style>
	</head>

	<body>
		<Header />
		<div class="page-wrapper">
			<main>
				<article>
					<div class="hero-image">
						{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
					</div>
					<div class="prose">
						<div class="article-header">
							<div class="article-meta">
								<span class="tag">{category}</span>
								<FormattedDate date={pubDate} />
								{updatedDate && (
									<span class="last-updated">
										（更新: <FormattedDate date={updatedDate} />）
									</span>
								)}
							</div>
							<h1>{title}</h1>
							<p class="article-desc">{description}</p>
							{tags && tags.length > 0 && (
								<div class="tags">
									{tags.map((tag: string) => <span class="tag">{tag}</span>)}
								</div>
							)}
						</div>
						{ADSENSE_ID && (
							<div class="ad-slot" style="margin: 2em 0; text-align: center; min-height: 100px;">
								<ins class="adsbygoogle"
									style="display:block"
									data-ad-client={ADSENSE_ID}
									data-ad-slot="auto"
									data-ad-format="auto"
									data-full-width-responsive="true"></ins>
							</div>
						)}
						<slot />
						{ADSENSE_ID && (
							<div class="article-end-ad">
								<div class="ad-label">広告</div>
								<ins class="adsbygoogle"
									style="display:block"
									data-ad-client={ADSENSE_ID}
									data-ad-slot="auto"
									data-ad-format="auto"
									data-full-width-responsive="true"></ins>
							</div>
						)}
						<div class="article-after-cta">
							<h3>{SIDEBAR_ADS[0].heading}</h3>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					</div>
				</article>
			</main>

			<!-- Sidebar -->
			<aside class="sidebar">
				<div class="sidebar-scroll">

					<div class="sidebar-author">
						<img src="/images/mascot.png" alt="動画オタク" width="64" height="64">
						<div>
							<strong>動画オタク</strong>
							<p>当サイトの運営者です</p>
						</div>
					</div>

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>{SIDEBAR_ADS[0].heading}</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-ad">
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>人気の記事</h4>
						{posts.slice(0, 5).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-cta-gradient">
							<h4>✨ おすすめ</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-banner">
							<div class="banner-label">PR</div>
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>おすすめ記事</h4>
						{posts.slice(5, 10).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>まだ迷ってる？</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-cta-gradient">
							<h4>🔥 今すぐチェック</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					<div class="sidebar-popular">
						<h4>新着記事</h4>
						{posts.slice(10, 15).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-banner">
							<div class="banner-label">注目</div>
							<h4>{SIDEBAR_ADS[0].heading}</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-cta-gradient">
							<h4>読者に人気</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>よく読まれている記事</h4>
						{posts.slice(0, 3).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>あなたへのおすすめ</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-banner">
							<div class="banner-label">PR</div>
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>カテゴリ人気記事</h4>
						{posts.slice(3, 8).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-cta-gradient">
							<h4>見逃してない？</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

				</div>
			</aside>
		</div>
		<Footer />

	<script is:inline>
		document.addEventListener('DOMContentLoaded', function() {
			document.querySelectorAll('.adsbygoogle').forEach(function() {
				try { (adsbygoogle = window.adsbygoogle || []).push({}); } catch(e) {}
			});
		});
	</script>
	</body>
</html>
