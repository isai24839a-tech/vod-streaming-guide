---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SIDEBAR_ADS, ADSENSE_ID } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`記事一覧 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.page-title {
				text-align: center;
				margin-bottom: 0.5em;
				border: none;
			}
			.page-desc {
				text-align: center;
				color: rgb(var(--gray));
				margin-bottom: 2em;
			}
			.posts-list {
				display: flex;
				flex-direction: column;
				gap: 1.2em;
			}
			.post-card {
				display: block;
				background: white;
				border-radius: var(--radius);
				padding: 1.5em;
				box-shadow: var(--box-shadow);
				text-decoration: none;
				color: rgb(var(--gray-dark));
				transition: box-shadow .2s, transform .2s;
			}
			.post-card:hover {
				box-shadow: var(--box-shadow-lg);
				transform: translateY(-3px);
				color: rgb(var(--gray-dark));
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.8em;
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin-bottom: 0.4em;
			}
			.post-card h3 {
				font-size: 1.15em;
				margin: 0 0 0.3em;
				line-height: 1.4;
				border: none;
			}
			.post-card p {
				font-size: 0.9em;
				color: rgb(var(--gray));
				margin: 0;
				line-height: 1.6;
			}
			.post-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.3em;
				margin-top: 0.6em;
			}
		</style>
	</head>
	<body>
		<Header />
		<div class="page-wrapper">
			<main>
			<h1 class="page-title">記事一覧</h1>
			<p class="page-desc">AIを活用した副業・収益化に関する記事をお届けします</p>
			<div class="posts-list">
				{posts.map((post) => (
					<a href={`/blog/${post.id}/`} class="post-card">
						<div class="post-meta">
							<span class="tag">{post.data.category}</span>
							<FormattedDate date={post.data.pubDate} />
						</div>
						<h3>{post.data.title}</h3>
						<p>{post.data.description}</p>
						{post.data.tags && post.data.tags.length > 0 && (
							<div class="post-tags">
								{post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
							</div>
						)}
					</a>
				))}
			</div>
			</main>

<!-- Sidebar -->
			<aside class="sidebar">
				<div class="sidebar-scroll">
					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>{SIDEBAR_ADS[0].heading}</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-ad">
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>人気の記事</h4>
						{posts.slice(0, 5).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-cta-gradient">
							<h4>✨ おすすめ</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-banner">
							<div class="banner-label">PR</div>
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>おすすめ記事</h4>
						{posts.slice(5, 10).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>まだ迷ってる？</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-cta-gradient">
							<h4>🔥 今すぐチェック</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					<div class="sidebar-popular">
						<h4>新着記事</h4>
						{posts.slice(10, 15).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-banner">
							<div class="banner-label">注目</div>
							<h4>{SIDEBAR_ADS[0].heading}</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-cta-gradient">
							<h4>読者に人気</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>よく読まれている記事</h4>
						{posts.slice(0, 3).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>あなたへのおすすめ</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-banner">
							<div class="banner-label">PR</div>
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>カテゴリ人気記事</h4>
						{posts.slice(3, 8).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-cta-gradient">
							<h4>見逃してない？</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

				</div>
			</aside>
		</div>
		<Footer />

	<script is:inline>
		document.addEventListener('DOMContentLoaded', function() {
			document.querySelectorAll('.adsbygoogle').forEach(function() {
				try { (adsbygoogle = window.adsbygoogle || []).push({}); } catch(e) {}
			});
		});
	</script>
	</body>
</html>
