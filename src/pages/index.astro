---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SITE_URL, SIDEBAR_ADS, ADSENSE_ID } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const siteId = SITE_URL.replace('https://', '').replace('.pages.dev', '');
const getThumb = (slug: string) => `/images/blog/${siteId}-${slug}-01.jpg`;
const now = new Date();
const sevenDaysAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
const isNew = (date: Date) => date >= sevenDaysAgo;
const categories = [...new Set(posts.map(p => p.data.category))];
const featuredPost = posts[0];
const restPosts = posts.slice(1);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<!-- Structured Data: WebSite -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": SITE_TITLE,
			"description": SITE_DESCRIPTION,
			"url": Astro.site ? Astro.site.href : ""
		})}></script>
	</head>
	<body>
		<Header />
		<div class="page-wrapper">
			<main>
				<!-- Hero (animated) -->
				<section class="hero">
					<div class="hero-bg"></div>
					<div class="hero-content">
						<h1>あなたの「観たい」<br><span class="gradient-text">ぜんぶ、ここにある</span></h1>
						<p class="hero-sub">Netflix・U-NEXT・Hulu・Amazon Prime…動画配信サービスの比較からYouTube・TikTok収益化まで徹底解説。</p>
						<div class="hero-stats">
							<div class="stat-item">
								<span class="stat-num">{posts.length}+</span>
								<span class="stat-label">記事</span>
							</div>
							<div class="stat-divider"></div>
							<div class="stat-item">
								<span class="stat-num">{categories.length}</span>
								<span class="stat-label">カテゴリ</span>
							</div>
							<div class="stat-divider"></div>
							<div class="stat-item">
								<span class="stat-num">毎週</span>
								<span class="stat-label">更新中</span>
							</div>
						</div>
						<a href="/blog" class="hero-btn">記事を読む →</a>
					</div>
				</section>

				<!-- Inline Banner Ad -->
				<section class="inline-banner">
					<h3>お得に動画配信を楽しもう</h3>
					<p>各サービスの無料体験を活用して、お気に入りを見つけよう</p>
					<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">詳しく見る →</a>
					<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
				</section>

				<!-- Featured Spotlight -->
				{featuredPost && (
					<section class="spotlight">
						<h2 class="section-title">PICK UP</h2>
						<a href={`/blog/${featuredPost.id}/`} class="spotlight-card">
							<div class="spotlight-img">
								<img src={getThumb(featuredPost.id)} alt="" loading="lazy" onerror="this.style.display='none'" />
								<div class="spotlight-img-fallback"></div>
								{isNew(featuredPost.data.pubDate) && <span class="badge-new">NEW</span>}
							</div>
							<div class="spotlight-body">
								<span class="tag">{featuredPost.data.category}</span>
								<h3>{featuredPost.data.title}</h3>
								<p>{featuredPost.data.description}</p>
								<span class="spotlight-date"><FormattedDate date={featuredPost.data.pubDate} /></span>
							</div>
						</a>
					</section>
				)}

				<!-- Ranking -->
				<section class="ranking-section">
					<h2 class="section-title">人気記事ランキング</h2>
					<div class="ranking-list">
						{posts.slice(0, 3).map((post, i) => (
							<a href={`/blog/${post.id}/`} class={`ranking-item rank-${i + 1}`}>
								<span class="ranking-number">{i + 1}</span>
								<div class="ranking-thumb">
									<img src={getThumb(post.id)} alt="" loading="lazy" onerror="this.style.display='none'" />
									<div class="ranking-thumb-fallback"></div>
								</div>
								<div class="ranking-content">
									<div class="ranking-meta">
										<span class="tag">{post.data.category}</span>
										{isNew(post.data.pubDate) && <span class="badge-new">NEW</span>}
									</div>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
								</div>
							</a>
						))}
					</div>
				</section>

				{ADSENSE_ID && (
					<div class="section-adsense">
						<div class="ad-label">広告</div>
						<ins class="adsbygoogle"
							style="display:block"
							data-ad-client={ADSENSE_ID}
							data-ad-slot="auto"
							data-ad-format="fluid"
							data-ad-layout-key="-6t+ed+2i-1n-4w"></ins>
					</div>
				)}

				<!-- Mid CTA -->
				<section class="cta-box">
					<h3>VODサービス選びに迷ったら</h3>
					<p>各サービスの特徴を徹底比較。あなたにぴったりのサービスが見つかります。</p>
					<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">おすすめサービスを見る →</a>
					<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
				</section>

				<!-- Latest Posts (with thumbnails) -->
				<section class="posts-section">
					<h2 class="section-title">最新記事</h2>
					<div class="posts-grid">
						{restPosts.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-card">
								<div class="post-card-thumb">
									<img src={getThumb(post.id)} alt="" loading="lazy" onerror="this.style.display='none'" />
									<div class="post-card-thumb-fallback"></div>
								</div>
								<div class="post-card-body">
									<div class="post-meta">
										<span class="tag">{post.data.category}</span>
										<FormattedDate date={post.data.pubDate} />
										{isNew(post.data.pubDate) && <span class="badge-new">NEW</span>}
									</div>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
								</div>
							</a>
						))}
					</div>
				</section>

				{ADSENSE_ID && (
					<div class="section-adsense">
						<div class="ad-label">広告</div>
						<ins class="adsbygoogle"
							style="display:block"
							data-ad-client={ADSENSE_ID}
							data-ad-slot="auto"
							data-ad-format="auto"
							data-full-width-responsive="true"></ins>
					</div>
				)}

				<!-- Bottom CTA -->
				<section class="cta-box">
					<h3>まずは無料体験から</h3>
					<p>多くのVODサービスは無料トライアルを提供中。リスクゼロで試せます。</p>
					<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">無料で始める →</a>
					<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
				</section>
			</main>

			<!-- Sidebar (unchanged - read from existing file) -->
			<!-- Sidebar -->
			<aside class="sidebar">
				<div class="sidebar-scroll">
					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>{SIDEBAR_ADS[0].heading}</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-ad">
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>人気の記事</h4>
						{posts.slice(0, 5).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-cta-gradient">
							<h4>✨ おすすめ</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-banner">
							<div class="banner-label">PR</div>
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>おすすめ記事</h4>
						{posts.slice(5, 10).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>どのサービスにする？</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-cta-gradient">
							<h4>🔥 今すぐチェック</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					<div class="sidebar-popular">
						<h4>新着記事</h4>
						{posts.slice(10, 15).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-banner">
							<div class="banner-label">注目</div>
							<h4>{SIDEBAR_ADS[0].heading}</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-cta-gradient">
							<h4>読者に人気</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>よく読まれている記事</h4>
						{posts.slice(0, 3).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>あなたへのおすすめ</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-banner">
							<div class="banner-label">PR</div>
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>カテゴリ人気記事</h4>
						{posts.slice(3, 8).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-cta-gradient">
							<h4>見逃してない？</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

				</div>
			</aside>
		</div>
		<div class="footer-ad-section">
			{ADSENSE_ID && (
				<div class="footer-adsense">
					<div class="ad-label">広告</div>
					<ins class="adsbygoogle"
						style="display:block"
						data-ad-client={ADSENSE_ID}
						data-ad-slot="auto"
						data-ad-format="auto"
						data-full-width-responsive="true"></ins>
				</div>
			)}
		</div>
		<Footer />

	<script is:inline>
		document.addEventListener('DOMContentLoaded', function() {
			document.querySelectorAll('.adsbygoogle').forEach(function() {
				try { (adsbygoogle = window.adsbygoogle || []).push({}); } catch(e) {}
			});
		});
	</script>
	</body>
</html>

<style>
	/* === Hero with animated background === */
	.hero {
		position: relative;
		text-align: center;
		padding: 3.5em 1em 2.5em;
		overflow: hidden;
		border-radius: var(--radius);
		margin-bottom: 0.5em;
	}
	.hero-bg {
		position: absolute;
		inset: 0;
		background: linear-gradient(-45deg, #6366f1, #8b5cf6, #a855f7, #ec4899, #6366f1);
		background-size: 400% 400%;
		animation: heroGradient 12s ease infinite;
		opacity: 0.08;
		border-radius: var(--radius);
	}
	@keyframes heroGradient {
		0% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
		100% { background-position: 0% 50%; }
	}
	.hero-content {
		position: relative;
		z-index: 1;
	}
	.hero h1 {
		font-size: 2.2em;
		line-height: 1.3;
		margin-bottom: 0.5em;
		border: none;
	}
	.gradient-text {
		background: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.hero-sub {
		font-size: 1.1em;
		color: rgb(var(--gray));
		margin-bottom: 1.2em;
	}

	/* Stats bar in hero */
	.hero-stats {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1.5em;
		margin-bottom: 1.5em;
		flex-wrap: wrap;
	}
	.stat-item {
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.stat-num {
		font-size: 1.5em;
		font-weight: 800;
		background: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		line-height: 1.2;
	}
	.stat-label {
		font-size: 0.8em;
		color: rgb(var(--gray));
		font-weight: 500;
	}
	.stat-divider {
		width: 1px;
		height: 2em;
		background: rgb(var(--gray-light));
	}

	.hero-btn {
		display: inline-block;
		background: var(--accent-gradient);
		color: white !important;
		padding: 0.7em 2em;
		border-radius: 50px;
		font-weight: 600;
		transition: transform .2s, box-shadow .2s;
		box-shadow: 0 4px 15px rgba(99,102,241,.3);
	}
	.hero-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(99,102,241,.4);
	}

	/* === Featured Spotlight === */
	.spotlight {
		margin-bottom: 2em;
	}
	.spotlight-card {
		display: block;
		background: white;
		border-radius: var(--radius);
		box-shadow: var(--box-shadow);
		overflow: hidden;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		transition: box-shadow .3s, transform .3s;
	}
	.spotlight-card:hover {
		box-shadow: var(--box-shadow-lg);
		transform: translateY(-4px);
		color: rgb(var(--gray-dark));
	}
	.spotlight-img {
		position: relative;
		width: 100%;
		height: 280px;
		overflow: hidden;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
	}
	.spotlight-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
	}
	.spotlight-img-fallback {
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, var(--accent), var(--accent-dark));
		z-index: -1;
	}
	.spotlight-img .badge-new {
		position: absolute;
		top: 1em;
		right: 1em;
		font-size: 0.85em;
		padding: 0.3em 0.8em;
	}
	.spotlight-body {
		padding: 1.5em;
	}
	.spotlight-body h3 {
		font-size: 1.3em;
		margin: 0.5em 0 0.4em;
		line-height: 1.4;
