---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SIDEBAR_ADS, ADSENSE_ID } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<!-- Structured Data: WebSite -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": SITE_TITLE,
			"description": SITE_DESCRIPTION,
			"url": Astro.site ? Astro.site.href : ""
		})}></script>
	</head>
	<body>
		<Header />
		<div class="page-wrapper">
			<main>
				<!-- Hero -->
				<section class="hero">
					<h1><br><span class="gradient-text">配信のミカタ</span>で稼ごう</h1>
					<p class="hero-sub">Netflix・U-NEXT・Hulu・Amazon Prime…動画配信サービスの比較からYouTube・TikTok収益化まで徹底解説。</p>
					<a href="/blog" class="hero-btn">記事を読む →</a>
				</section>

				<!-- Inline Banner Ad -->
				<section class="inline-banner">
					<h3>お得に動画配信を楽しもう</h3>
					<p>各サービスの無料体験を活用して、お気に入りを見つけよう</p>
					<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">詳しく見る →</a>
					<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
				</section>

				<!-- 人気記事ランキング -->
				<section class="ranking-section">
					<h2 class="section-title">🔥 人気記事ランキング</h2>
					<div class="ranking-list">
						{posts.slice(0, 3).map((post, i) => (
							<a href={`/blog/${post.id}/`} class={`ranking-item rank-${i + 1}`}>
								<span class="ranking-number">{i + 1}</span>
								<div class="ranking-content">
									<span class="tag">{post.data.category}</span>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
								</div>
							</a>
						))}
					</div>
				</section>

				{ADSENSE_ID && (
					<div class="section-adsense">
						<div class="ad-label">広告</div>
						<ins class="adsbygoogle"
							style="display:block"
							data-ad-client={ADSENSE_ID}
							data-ad-slot="auto"
							data-ad-format="fluid"
							data-ad-layout-key="-6t+ed+2i-1n-4w"></ins>
					</div>
				)}

				<!-- Mid CTA -->
				<section class="cta-box">
					<h3>VODサービス選びに迷ったら</h3>
					<p>各サービスの特徴を徹底比較。あなたにぴったりのサービスが見つかります。</p>
					<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">比較記事を見る →</a>
					<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
				</section>

				<!-- Featured Posts -->
				<section class="posts-section">
					<h2 class="section-title">最新記事</h2>
					<div class="posts-grid">
						{posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-card">
								<div class="post-meta">
									<span class="tag">{post.data.category}</span>
									<FormattedDate date={post.data.pubDate} />
								</div>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
							</a>
						))}
					</div>
				</section>

				{ADSENSE_ID && (
					<div class="section-adsense">
						<div class="ad-label">広告</div>
						<ins class="adsbygoogle"
							style="display:block"
							data-ad-client={ADSENSE_ID}
							data-ad-slot="auto"
							data-ad-format="auto"
							data-full-width-responsive="true"></ins>
					</div>
				)}

				<!-- Bottom CTA -->
				<section class="cta-box">
					<h3>まずは無料体験から</h3>
					<p>多くのVODサービスは無料トライアルを提供中。リスクゼロで試せます。</p>
					<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">無料体験する →</a>
					<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
				</section>
			</main>

			<!-- Sidebar -->
			<aside class="sidebar">
				<div class="sidebar-scroll">
					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>{SIDEBAR_ADS[0].heading}</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-ad">
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>人気の記事</h4>
						{posts.slice(0, 5).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-cta-gradient">
							<h4>✨ おすすめ</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-banner">
							<div class="banner-label">PR</div>
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>おすすめ記事</h4>
						{posts.slice(5, 10).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>まだ迷ってる？</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-cta-gradient">
							<h4>🔥 今すぐチェック</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					<div class="sidebar-popular">
						<h4>新着記事</h4>
						{posts.slice(10, 15).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-banner">
							<div class="banner-label">注目</div>
							<h4>{SIDEBAR_ADS[0].heading}</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-cta-gradient">
							<h4>読者に人気</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>よく読まれている記事</h4>
						{posts.slice(0, 3).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>あなたへのおすすめ</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-banner">
							<div class="banner-label">PR</div>
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>カテゴリ人気記事</h4>
						{posts.slice(3, 8).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-cta-gradient">
							<h4>見逃してない？</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

				</div>
			</aside>
		</div>
		<div class="footer-ad-section">
			{ADSENSE_ID && (
				<div class="footer-adsense">
					<div class="ad-label">広告</div>
					<ins class="adsbygoogle"
						style="display:block"
						data-ad-client={ADSENSE_ID}
						data-ad-slot="auto"
						data-ad-format="auto"
						data-full-width-responsive="true"></ins>
				</div>
			)}
		</div>
		<Footer />

	<script is:inline>
		document.addEventListener('DOMContentLoaded', function() {
			document.querySelectorAll('.adsbygoogle').forEach(function() {
				try { (adsbygoogle = window.adsbygoogle || []).push({}); } catch(e) {}
			});
		});
	</script>
	</body>
</html>

<style>
	.hero {
		text-align: center;
		padding: 3em 0 2em;
	}
	.hero h1 {
		font-size: 2.2em;
		line-height: 1.3;
		margin-bottom: 0.5em;
		border: none;
	}
	.gradient-text {
		background: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.hero-sub {
		font-size: 1.1em;
		color: rgb(var(--gray));
		margin-bottom: 1.5em;
	}
	.hero-btn {
		display: inline-block;
		background: var(--accent-gradient);
		color: white !important;
		padding: 0.7em 2em;
		border-radius: 50px;
		font-weight: 600;
		transition: transform .2s, box-shadow .2s;
		box-shadow: 0 4px 15px rgba(99,102,241,.3);
	}
	.hero-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(99,102,241,.4);
	}
	.section-title {
		font-size: 1.4em;
		border: none;
		text-align: center;
		margin-bottom: 1em;
	}
	.posts-grid {
		display: grid;
		gap: 1.2em;
	}
	.post-card {
		display: block;
		background: white;
		border-radius: var(--radius);
		padding: 1.5em;
		box-shadow: var(--box-shadow);
		text-decoration: none;
		color: rgb(var(--gray-dark));
		transition: box-shadow .2s, transform .2s;
	}
	.post-card:hover {
		box-shadow: var(--box-shadow-lg);
		transform: translateY(-3px);
		color: rgb(var(--gray-dark));
	}
	.post-card h3 {
		font-size: 1.15em;
		margin: 0.5em 0 0.3em;
		line-height: 1.4;
	}
	.post-card p {
		font-size: 0.9em;
		color: rgb(var(--gray));
		margin: 0;
		line-height: 1.6;
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.8em;
		font-size: 0.8em;
		color: rgb(var(--gray));
	}
	@media (max-width: 720px) {
		.hero h1 { font-size: 1.6em; }
		.hero-sub { font-size: 0.95em; }
	}

	.ranking-section {
		margin-bottom: 2em;
	}
	.ranking-list {
		display: flex;
		flex-direction: column;
		gap: 0.8em;
	}
	.ranking-item {
		display: flex;
		align-items: flex-start;
		gap: 1em;
		background: white;
		border-radius: var(--radius);
		padding: 1.2em;
		box-shadow: var(--box-shadow);
		text-decoration: none;
		color: rgb(var(--gray-dark));
		transition: box-shadow .2s, transform .2s;
		border-left: 4px solid transparent;
	}
	.ranking-item:hover {
		box-shadow: var(--box-shadow-lg);
		transform: translateY(-2px);
		color: rgb(var(--gray-dark));
	}
	.ranking-item.rank-1 { border-left-color: #fbbf24; }
	.ranking-item.rank-2 { border-left-color: #9ca3af; }
	.ranking-item.rank-3 { border-left-color: #cd7c2f; }
	.ranking-number {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.2em;
		height: 2.2em;
		border-radius: 50%;
		font-weight: 800;
		font-size: 1.1em;
		flex-shrink: 0;
		color: white;
	}
	.rank-1 .ranking-number { background: linear-gradient(135deg, #fbbf24, #f59e0b); }
	.rank-2 .ranking-number { background: linear-gradient(135deg, #9ca3af, #6b7280); }
	.rank-3 .ranking-number { background: linear-gradient(135deg, #cd7c2f, #b45309); }
	.ranking-content h3 {
		font-size: 1.05em;
		margin: 0.3em 0 0.2em;
		line-height: 1.4;
	}
	.ranking-content p {
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin: 0;
		line-height: 1.5;
	}
	.ranking-content .tag {
		font-size: 0.75em;
	}
</style>
